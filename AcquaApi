        public static void AcquaProcessKill()
        {
            if (AcquaApp == null)
            {
                WriteLog(ELogType.Warn, "AcquaApp is null.");
            }

            AcquaApp = null;

            foreach (Process proc in Process.GetProcessesByName("Acqua3"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
            foreach (Process proc in Process.GetProcessesByName("Acqua4"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
            foreach (Process proc in Process.GetProcessesByName("Acqua5"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
            foreach (Process proc in Process.GetProcessesByName("Acqua6"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
            foreach (Process proc in Process.GetProcessesByName("ACQUAlyzer"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
            foreach (Process proc in Process.GetProcessesByName("HaspLicenseServer"))
            {
                proc.Kill();
                proc.WaitForExit();
            }
        }


