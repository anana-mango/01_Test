        public static void AcquaStart()
        {
            // ACQUA 실행
            AcquaApp = new Acqua3.AcquaApplication();

            // 아래 반복문 정상 작동 시 아래 주석 삭제
            while (!AcquaApp.AppLoadFinished) ;


            Thread.Sleep(5000);
            AcquaMeasurementEngine = new HEADACQUAlyzer.MeasurementEngine();
            AcquaFrontends = AcquaMeasurementEngine.Frontends;


            #region Variables

            AcquaVariables = new HEADACQUAlyzer.Variables();
            string varFileName = _SystemVarsPath;
            AcquaVariables.Filename = varFileName;

            #endregion Variables


            #region MFE Series

            AcquaMfeControl = new MfeControlLib.MfeControl();
            if (AcquaMfeControl != null)
            {
                WriteLog(ELogType.Info, string.Format("AcquaMfeControl.Count : {0}", AcquaMfeControl.Count));
                WriteLog(ELogType.Info, string.Format("Mfe6Count : {0}", AcquaMfeControl.Mfe6Count));
                WriteLog(ELogType.Info, string.Format("Mfe8Count : {0}", AcquaMfeControl.Mfe8Count));
                WriteLog(ELogType.Info, string.Format("Mfe11Count : {0}", AcquaMfeControl.Mfe11Count));
            }
            else WriteLog(ELogType.Debug, "AcquaMfeControl.Count : null");

            #endregion MFE Series


            #region labCORE

            AcquaLabCoreControl = new MfeControlLib.LabCoreControl();
            if (AcquaLabCoreControl != null)
            {
                if (AcquaLabCoreControl.Count != 0)
                {
                    AcquaLabCoreBlock = AcquaLabCoreControl[0].AudioWiring.Blocks;

                    MfeControlLib.IBlockBase acquaLabCoreBlockBase;

                    acquaLabCoreBlockBase = AcquaLabCoreBlock.FirstBlockByType(EBlockType.eBlockTypeBluetooth);
                    if (acquaLabCoreBlockBase != null)
                    {
                        AcquaLabCoreBt = acquaLabCoreBlockBase as ILabCoreAudioBlockBluetooth;
                        WriteLog(ELogType.Info, "labCORE " + AcquaLabCoreBt.Name + " exist.");
                    }
                    else WriteLog(ELogType.Warn, "labCORE eBlockTypeBluetooth does not exist.");

                    acquaLabCoreBlockBase = AcquaLabCoreBlock.FirstBlockByType(EBlockType.eBlockTypeVoIP);
                    if (acquaLabCoreBlockBase != null)
                    {
                        AcquaLabCoreVoip = AcquaLabCoreBlock.FirstBlockByType(EBlockType.eBlockTypeVoIP).Settings;
                        WriteLog(ELogType.Info, "labCORE ILabCoreAudioBlockSettingsVoIP exist.");
                    }
                    else WriteLog(ELogType.Warn, "labCORE eBlockTypeVoIP does not exist.");

                    IsLabCoreAvailable = AcquaMeasurementEngine.Labcore.IsConnected;
                }
            }
            else WriteLog(ELogType.Debug, "AcquaLabCoreControl.Count : null");

            #endregion labCORE

            BtHfpBrsf = new BitArray(Enum.GetNames(typeof(EBtHfpBrsf)).Length);
            BtHfpBrsf.Set((int)EBtHfpBrsf.NrEc, false);
            BtHfpBrsf.Set((int)EBtHfpBrsf.CallWatingAnd3WayCalling, false);
            BtHfpBrsf.Set((int)EBtHfpBrsf.CLIPresentationCapability, false);
            BtHfpBrsf.Set((int)EBtHfpBrsf.VoiceRecognitionActivation, true);
            BtHfpBrsf.Set((int)EBtHfpBrsf.RemoteVolumeControl, true);
            BtHfpBrsf.Set((int)EBtHfpBrsf.EnhancedCallStatus, true);
            BtHfpBrsf.Set((int)EBtHfpBrsf.EnhancedCallControl, true);
            BtHfpBrsf.Set((int)EBtHfpBrsf.WidebandCodecNegotiation, false);

            AcquaApp.OnBeginSingleMeasurement -= AcquaApp_OnBeginSingleMeasurement;
            AcquaApp.OnFinishedSingleMeasurement -= AcquaApp_OnFinishedSingleMeasurement;

            AcquaApp.OnBeginSingleMeasurement += AcquaApp_OnBeginSingleMeasurement;
            AcquaApp.OnFinishedSingleMeasurement += AcquaApp_OnFinishedSingleMeasurement;
        }

