        public static IProjectgroup CurrentAcquaProjectGroup
        {
            get { return _AcquaIProjectgroup; }
            set
            {
                CurrentProjectGroupIndex = 0;

                if (value != null)
                {
                    foreach (Acqua3.IProjectgroup projectGroup in AcquaApp.ProjectGroups)
                    {
                        if (value.Title == projectGroup.Title) break;
                        CurrentProjectGroupIndex++;
                    }

                    CurrentProjectGroupTitle = value.Title;
                }
                _AcquaIProjectgroup = value;
            }
        }

        public static IProject CurrentAcquaProject
        {
            get { return _AcquaIProject; }
            set
            {
                SmdTitleOverLap.Clear();
                CurrentProjectIndex = 0;

                if (value != null)
                {
                    _AcquaIProjectgroup = AcquaApp.ProjectGroups.Item[CurrentProjectGroupIndex];
                    foreach (Acqua3.IProject project in CurrentAcquaProjectGroup.Projects)
                    {
                        if (value.Title == project.Title) break;
                        CurrentProjectIndex++;
                    }

                    CurrentProjectTitle = value.Title;
                }
                _AcquaIProject = value;
            }
        }

