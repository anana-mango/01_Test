        /// <summary>
        /// String "HS" or "BT"
        /// </summary>
        /// <param name="mode"></param>
        /// <returns></returns>
        public static bool CheckMfeConnect(string mode = "HS")
        {
            try
            {
                //_Mfe6Connected = AcquaMeasurementEngine.Mfe6.IsConnected;
                //_Mfe11Connected = AcquaMeasurementEngine.Mfe11.IsConnected;

                //if (!AcquaMeasurementEngine.Mfe6.IsConnected)
                if (!Mfe6Connected)
                {
                    WriteLog(ELogType.Warn, "MFE6 is not connected!!");

                    return false;
                }
                WriteLog(ELogType.Info, "MFE6 is connected");

                if (mode == "BT" && !Mfe11Connected)
                {
                    WriteLog(ELogType.Warn, "MFE11 is not connected!!");

                    return false;
                }
                if (Mfe11Connected) WriteLog(ELogType.Info, "MFE11 is connected");

                if (mode == "BT" && Mfe11Connected && Mfe6Connected) return true;
                else if (mode == "HS" && Mfe6Connected) return true;
                else return false;

            }
            catch (Exception ex)
            {
                WriteLog(ELogType.Error, "CheckMfeConnect() Exception : " + ex);
                return false;
            }

        }

        public static bool MfeFrontendCheck(string mode = "HS")
        {
            try
            {
                CheckMfeConnect(mode);

                //if (mode == "BT" && _Mfe11Connected && _Mfe6Connected) return true;
                //if (mode == "HS" && _Mfe6Connected) return true;

                string MFE6 = "";
                bool MFE6_on = false;
                string MFE11 = "";
                bool MFE11_on = false;
                string MFE81 = "";
                bool MFE81_on = false;

                for (int i = 0; i < AcquaFrontends.Count; i++)
                {
                    WriteLog(0, AcquaFrontends[i].Name);

                    if (AcquaFrontends[i].Name.Contains("XI "))
                    {
                        MFE11 = AcquaFrontends[i].Name;
                        MFE11_on = AcquaFrontends[i].Enabled;
                        //Mfe11Connected = true;
                    }
                    else if (AcquaFrontends[i].Name.Contains("VI "))
                    {
                        MFE6 = AcquaFrontends[i].Name;
                        MFE6_on = AcquaFrontends[i].Enabled;
                        //Mfe6Connected = true;
                    }
                    else if (AcquaFrontends[i].Name.Contains("VIII"))
                    {
                        MFE81 = AcquaFrontends[i].Name;
                        MFE81_on = AcquaFrontends[i].Enabled;
                    }

                } //여기서 MFE 이름과 Activate유무 파악.

                if (mode == "HS" && MFE6_on == false)
                    WriteLog(ELogType.Info, (AcquaFrontends.ActiveFrontend = MFE6) + " Activated");
                if (mode == "BT" && MFE11_on == false)
                    WriteLog(ELogType.Info, (AcquaFrontends.ActiveFrontend = MFE11) + " Activated");


                Thread.Sleep(2500);

                HardwareConfigSet(mode);

                if (AcquaMeasurementEngine.HardwareConfig.Settings.ActiveSetting == null ||
                    AcquaMeasurementEngine.HardwareConfig.Settings.ActiveSetting != mode)
                {
                    WriteLog(ELogType.Warn, "Setting 오류");
                    return false;
                }
                else
                    WriteLog(ELogType.Debug, "HardwareConfig : " + mode);

                return true;
            }
            catch (Exception ex)
            {
                WriteLog(ELogType.Error, "Hardware config ex Process has stopped!\n" + ex.Message);
                //_FormMain.Knox_SendMSG("Hardware config ex! Process has stopped!\n" + ex.Message);
            }

            return true;
        }

